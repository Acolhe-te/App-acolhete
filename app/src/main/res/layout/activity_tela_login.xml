<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8F7F2"
    tools:context=".telaLogin">

    <TextView
        android:id="@+id/textView2"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="@font/poppins_semibold"
        android:text="Login"
        android:textColor="#000000"
        android:textSize="60sp"
        tools:layout_editor_absoluteX="25dp"
        tools:layout_editor_absoluteY="99dp" />

    <TextView
        android:id="@+id/textView4"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="@font/poppins_medium"
        android:text="Continue sua jornada com a gente."
        android:textSize="14sp"
        tools:layout_editor_absoluteX="25dp"
        tools:layout_editor_absoluteY="217dp" />

    <TextView
        android:id="@+id/textView3"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="@font/poppins_medium"
        android:text="Bem vindo de volta!"
        android:textSize="14sp"
        app:layout_constraintBottom_toTopOf="@+id/textView4"
        tools:layout_editor_absoluteX="25dp" />

    <EditText
        android:id="@+id/editTextText4"
        style="@style/Widget.AppCompat.EditText"
        android:layout_width="359dp"
        android:layout_height="50dp"
        android:background="@android:drawable/edit_text"
        android:backgroundTint="#817435"
        android:ems="10"
        android:inputType="text"
        tools:layout_editor_absoluteX="25dp"
        tools:layout_editor_absoluteY="325dp" />

    <EditText
        android:id="@+id/editTextText3"
        android:layout_width="359dp"
        android:layout_height="50dp"
        android:layout_marginBottom="9dp"
        android:backgroundTint="#F8F7F2"
        android:ems="10"
        android:inputType="text"
        app:layout_constraintBottom_toTopOf="@+id/textView8"
        tools:layout_editor_absoluteX="25dp" />

    <TextView
        android:id="@+id/textView7"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="@font/poppins"
        android:text="Ocultar"
        android:textColor="#666666"
        tools:layout_editor_absoluteX="332dp"
        tools:layout_editor_absoluteY="412dp" />

    <TextView
        android:id="@+id/textView5"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        android:fontFamily="@font/poppins"
        android:text="Seu email"
        android:textColor="#666666"
        app:layout_constraintBottom_toTopOf="@+id/editTextText4"
        tools:layout_editor_absoluteX="25dp" />

    <TextView
        android:id="@+id/textView8"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="@font/poppins_medium"
        android:text="Esqueceu a senha?"
        android:textSize="13sp"
        tools:layout_editor_absoluteX="258dp"
        tools:layout_editor_absoluteY="495dp" />

    <ImageView
        android:id="@+id/imageView3"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:srcCompat="@drawable/icon"
        tools:layout_editor_absoluteX="308dp"
        tools:layout_editor_absoluteY="412dp" />

    <TextView
        android:id="@+id/textView6"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        android:fontFamily="@font/poppins"
        android:text="Sua senha"
        android:textColor="#666666"
        app:layout_constraintBottom_toTopOf="@+id/editTextText3"
        tools:layout_editor_absoluteX="25dp" />

    <ImageView
        android:id="@+id/imageView2"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:srcCompat="@drawable/vector"
        tools:layout_editor_absoluteX="25dp"
        tools:layout_editor_absoluteY="35dp" />

    <Button
        android:id="@+id/button3"
        android:layout_width="355dp"
        android:layout_height="64dp"
        android:layout_marginBottom="12dp"
        android:backgroundTint="#FF735C"
        android:fontFamily="@font/poppins_semibold"
        android:text="Acessar conta"
        android:textSize="20sp"
        app:layout_constraintBottom_toTopOf="@+id/textView9"
        tools:layout_editor_absoluteX="26dp" />

    <TextView
        android:id="@+id/textView9"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="@font/poppins_medium"
        android:text="Continue sem login"
        android:textSize="13sp"
        tools:layout_editor_absoluteX="141dp"
        tools:layout_editor_absoluteY="625dp" />

    <View
        android:id="@+id/view2"
        android:layout_width="369dp"
        android:layout_height="1dp"
        android:background="#000000"
        tools:layout_editor_absoluteX="21dp"
        tools:layout_editor_absoluteY="668dp" />

    <TextView
        android:id="@+id/textView10"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="6dp"
        android:fontFamily="@font/poppins_medium"
        android:text="Não tem conta?"
        android:textSize="14sp"
        app:layout_constraintEnd_toStartOf="@+id/textView12"
        tools:layout_editor_absoluteY="687dp" />

    <TextView
        android:id="@+id/textView12"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="@font/poppins_medium"
        android:text="Cadastre-se"
        android:textColor="#FF735C"
        android:textSize="14sp"
        tools:layout_editor_absoluteX="217dp"
        tools:layout_editor_absoluteY="687dp" />

</androidx.constraintlayout.widget.ConstraintLayout>